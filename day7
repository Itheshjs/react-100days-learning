Try yourself first.

13. Solution
App.jsx
import Student from "./Student";

function App() {
  return (
    <>
      <Student
        name="Ithesh"
        age={22}
        course="React"
      />
    </>
  );
}

export default App;
Student.jsx
function Student({
  name,
  age,
  course
}) {
  return (
    <div>
      <h2>Name: {name}</h2>
      <h2>Age: {age}</h2>
      <h2>Course: {course}</h2>
    </div>
  );
}

export default Student;
