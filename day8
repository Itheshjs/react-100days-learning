Real-Life Example

Imagine a registration form:

function App() {
  function handleChange(e) {
    console.log(e.target.value);
  }

  function handleSubmit(e) {
    e.preventDefault();
    alert("Form Submitted");
  }

  return (
    <form onSubmit={handleSubmit}>
      <input
        type="text"
        onChange={handleChange}
      />

      <button type="submit">
        Submit
      </button>
    </form>
  );
}
