13. Solution
import { useState } from "react";

function App() {
  const [text, setText] = useState("");

  return (
    <>
      <textarea
        value={text}
        onChange={(e) => setText(e.target.value)}
      />

      <h3>
        Characters: {text.length}
      </h3>
    </>
  );
}

export default App;
