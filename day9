13. Solution
import { useState } from "react";

function App() {
  const [text, setText] = useState("");

  return (
    <>
      <input
        type="text"
        onChange={(e) =>
          setText(e.target.value)
        }
      />

      <h2>
        Characters: {text.length}
      </h2>
    </>
  );
}

export default App;
