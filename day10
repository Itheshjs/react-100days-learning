13. Solution
import { useState } from "react";

function App() {

  const [color, setColor] = useState("white");

  function changeColor() {
    setColor("yellow");
  }

  return (
    <div
      style={{
        backgroundColor: color,
        height: "100vh"
      }}
    >
      <button onClick={changeColor}>
        Change Background
      </button>
    </div>
  );
}

export default App;
