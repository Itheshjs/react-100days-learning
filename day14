Mini Challenge

Create a Student Profile component.

Requirements:

Name: Empty
Age: 18

Buttons:

Set Name
Increase Age
Reset

Try yourself before seeing solution.

Solution
import { useState } from "react";

function App() {

  const [name, setName] = useState("");
  const [age, setAge] = useState(18);

  function resetData() {
    setName("");
    setAge(18);
  }

  return (
    <>
      <h1>Name: {name}</h1>
      <h1>Age: {age}</h1>

      <button onClick={() => setName("Ithesh")}>
        Set Name
      </button>

      <button onClick={() => setAge(age + 1)}>
        Increase Age
      </button>

      <button onClick={resetData}>
        Reset
      </button>
    </>
  );
}

export default App;
